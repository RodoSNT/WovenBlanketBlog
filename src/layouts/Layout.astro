---
import { SEO } from 'astro-seo';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
}

const { title, description, image, type = 'website' } = Astro.props;
const canonicalUrl = Astro.url.href;
const siteName = 'Woven Art Decor';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <SEO
    title={`${title} | ${siteName}`}
    description={description}
    canonical={canonicalUrl}
    openGraph={{
      basic: {
        title: title,
        type: type,
        image: image ?? '/og-default.jpg',
        url: canonicalUrl,
      },
      optional: {
        description: description,
        siteName: siteName,
      },
    }}
    twitter={{
      card: 'summary_large_image',
      title: title,
      description: description,
      image: image,
    }}
  />
  <style>
    :root {
      --color-bg: #0f0f0f;
      --color-surface: #1a1a1a;
      --color-border: #2a2a2a;
      --color-text: #e8e8e8;
      --color-text-muted: #999;
      --color-accent: #c9a96e;
      --color-accent-hover: #dbb978;
      --color-link: #c9a96e;
      --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --font-serif: 'Georgia', 'Times New Roman', serif;
      --max-width: 1100px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font-sans);
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    a { color: var(--color-link); text-decoration: none; }
    a:hover { color: var(--color-accent-hover); }

    .container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 24px;
    }

    /* Header */
    .site-header {
      border-bottom: 1px solid var(--color-border);
      padding: 20px 0;
    }
    .site-header .container {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .site-logo {
      font-family: var(--font-serif);
      font-size: 1.4rem;
      color: var(--color-accent);
      font-weight: 600;
      letter-spacing: 0.02em;
    }
    .site-nav { display: flex; gap: 24px; }
    .site-nav a {
      color: var(--color-text-muted);
      font-size: 0.9rem;
      transition: color 0.2s;
    }
    .site-nav a:hover { color: var(--color-text); }

    /* Main */
    main { padding: 48px 0 80px; }

    /* Footer */
    .site-footer {
      border-top: 1px solid var(--color-border);
      padding: 40px 0;
      color: var(--color-text-muted);
      font-size: 0.85rem;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 32px;
    }
    .footer-col h4 {
      color: var(--color-text);
      margin-bottom: 12px;
      font-size: 0.9rem;
    }
    .footer-col ul { list-style: none; }
    .footer-col li { margin-bottom: 8px; }
    .footer-col a { color: var(--color-text-muted); font-size: 0.85rem; }
    .footer-col a:hover { color: var(--color-accent); }

    @media (max-width: 640px) {
      .site-nav { gap: 16px; }
      .site-nav a { font-size: 0.8rem; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-logo">Woven Art Decor</a>
      <nav class="site-nav">
        <a href="/">Home</a>
        <a href="/gift-guides/gifts-for-her">Gift Guides</a>
        <a href="/guides/woven-blanket-buying-guide">Buying Guide</a>
      </nav>
    </div>
  </header>

  <main>
    <div class="container">
      <slot />
    </div>
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>Collections</h4>
          <ul id="footer-niches"></ul>
        </div>
        <div class="footer-col">
          <h4>Gift Guides</h4>
          <ul>
            <li><a href="/gift-guides/gifts-for-her">Gifts for Her</a></li>
            <li><a href="/gift-guides/gifts-for-book-lovers">Gifts for Book Lovers</a></li>
            <li><a href="/gift-guides/gothic-gifts">Gothic Gifts</a></li>
            <li><a href="/gift-guides/housewarming-gifts">Housewarming Gifts</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Learn</h4>
          <ul>
            <li><a href="/guides/woven-blanket-buying-guide">Buying Guide</a></li>
            <li><a href="/guides/cotton-blanket-care">Care Instructions</a></li>
            <li><a href="/guides/woven-blanket-sizes">Size Guide</a></li>
          </ul>
        </div>
      </div>
      <p style="margin-top: 32px; text-align: center;">
        Woven Art Decor &mdash; Curated woven blankets for every aesthetic.
      </p>
    </div>
  </footer>
</body>
</html>
